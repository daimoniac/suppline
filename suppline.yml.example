version: 1

creds:
  - registry: registry-1.docker.io
    user: '{{ env "DOCKER_USERNAME" }}'
    pass: '{{ env "DOCKER_PASSWORD" }}'
    repoAuth: false
    reqPerSec: 10
    reqConcurrent: 10
  - registry: docker.io
    user: '{{ env "DOCKER_USERNAME" }}'
    pass: '{{ env "DOCKER_PASSWORD" }}'
    repoAuth: false
    reqPerSec: 10
    reqConcurrent: 10

defaults:
  parallel: 4
  interval: 60m
  x-cosignRepository: myprivateregistry/suppline-cosign  # Optional: store cosign artifacts in a dedicated repository namespace
  cleanupTags: true
  cleanupTagsExclude:
  - ".*\\.sig$"
  - ".*\\.att$"
  x-rescanInterval: 1d
  x-runtimeInUseWindow: 7d
  x-worker-poll-interval: 5m
  x-worker-concurrency: 3
  x-worker-retry-attempts: 3
  x-worker-retry-backoff: 10s
  x-queue-buffer-size: 1000
  x-scaiValidityExtension: 7d
  x-policy:                   # Default policy for all sync entries (optional)
    expression: "criticalCount == 0"
    failureMessage: "critical vulnerabilities found"
    minimumReleaseAge: "7d"   # Only allow images released at least 7 days ago (optional)
  x-vex-repo: true            # Apply Aqua VEX Hub to all scans by default (optional)

sync:
  - source: nginx
    target: myprivateregistry/nginx
    type: repository
    schedule: "0 */6 * * *"
    x-rescanInterval: 3d      # Override default rescan interval for this entry (optional)
    x-vex:                     # VEX (Vulnerability Exploitability Exchange) statements
      - id: CVE-2024-56171
        state: not_affected
        justification: vulnerable_code_not_present
        detail: initial VEX statement when introducing supplychain
        expires_at: 2025-12-31T23:59:59Z
      - id: CVE-2025-0838
        state: not_affected
        justification: vulnerable_code_not_in_execute_path
        detail: no fix available, accepted risk

  - source: alpine
    target: myprivateregistry/alpine
    type: repository
    tags:
      semverRange:
        - ">=3.18.0"
      deny:
        - "latest"
    x-policy:                 # Override default policy for this entry (optional)
      expression: "criticalCount == 0 && highCount == 0"
      failureMessage: "critical or high vulnerabilities found"
      minimumReleaseAge: "14d" # Override: require images to be at least 14 days old (optional)
    x-vex:
      - id: CVE-2024-12345
        state: false_positive
        detail: not applicable to our use case
        expires_at: 2025-06-30T23:59:59Z

  - source: internal-tool
    target: myprivateregistry/internal-tool
    type: repository
    x-vex-repo: false         # Disable VEX for images with no upstream OSS VEX data (optional)

  - source: legacy-app
    target: myprivateregistry/legacy-app
    type: repository
    x-supplineIgnore: true    # Set to true to skip this entry entirely (default: false)
